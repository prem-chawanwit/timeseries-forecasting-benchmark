{
    "dataset": {
        "raw_data_path": "data/1_raw/kaggle_solar_merged.csv",
        "time_column": "DATE_TIME",
        "resample_freq": "1h"
    },
    "forecasting": {
        "target_source_column": "AC_POWER",
        "target_shift_steps": -1,
        "target_column_name": "target",
        "exclude_features": [
            "AC_POWER",
            "DC_POWER",
            "TOTAL_YIELD"
        ],
        "top_k_features": 5
    },
    "feature_engineering": {
        "add_time_features": true,
        "lag_features": {
            "columns": ["IRRADIATION", "MODULE_TEMPERATURE", "AC_POWER"],
            "lags": [1, 23, 24, 25, 48]
        }
    },
    "validation": {
        "global_test_size_ratio": 0.15,
        "n_splits": 10
    },
    "model_params": {
        "lstm": {
            "seq_length": 5,
            "epochs": 20,
            "learning_rate": 0.01
        },
        "xgboost": {
            "n_estimators": 100,
            "max_depth": 5,
            "learning_rate": 0.1
        }
    }
}