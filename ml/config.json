{
    "dataset": {
        "raw_data_path": "data/1_raw/metropt-3-dataset/MetroPT3(AirCompressor).csv",
        "resample_freq": "1h",
        "time_column": "timestamp"
    },
    "feature_engineering": {
        "add_time_features": true,
        "lag_features": {
            "columns": [
                "TP3",
                "DV_pressure",
                "Oil_temperature",
                "Motor_current",
                "TP2"
            ],
            "lags": [
                1,
                23,
                24,
                25,
                48
            ]
        }
    },
    "forecasting": {
        "exclude_features": [
            "TP2",
            "TP3",
            "H1"
        ],
        "target_column_name": "target",
        "target_shift_steps": -1,
        "target_source_column": "TP2",
        "top_k_features": 5
    },
    "model_params": {
        "lstm": {
            "epochs": 2000,
            "learning_rate": 0.01,
            "seq_length": 20
        },
        "xgboost": {
            "learning_rate": 0.1,
            "max_depth": 10,
            "n_estimators": 100
        }
    },
    "validation": {
        "global_test_size_ratio": 0.15,
        "n_splits": 10
    }
}